# Auto-detect text files and normalize line endings to LF (Linux/Mac standard)
* text=auto eol=lf

# Explicitly set line endings for specific file types
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.py text eol=lf
*.sh text eol=lf

# Tell GitHub to ignore certain folders when calculating the repo's languages
backend/data/** linguist-generated=true
frontend/.next/** linguist-generated=true