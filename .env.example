# ==============================================================================
# DocThread Environment Configuration (Template)
# Copy this file to .env and fill in your values. DO NOT commit .env to Git.
# ==============================================================================

# ------------------------------------------------------------------------------
# Bring Your Own Key (BYOK) - AI Providers
# Add the key for the provider you want to use. LiteLLM handles the routing.
# ------------------------------------------------------------------------------
OPENAI_API_KEY="your_openai_api_key_here"
# ANTHROPIC_API_KEY="your_anthropic_api_key_here"
# GEMINI_API_KEY="your_gemini_api_key_here"

# ------------------------------------------------------------------------------
# App Configuration
# ------------------------------------------------------------------------------
ENVIRONMENT="development"
FRONTEND_PORT=3000
BACKEND_PORT=8000